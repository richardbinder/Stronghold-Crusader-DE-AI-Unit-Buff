<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" IsEnabled="{Binding IsHost}">

            <TextBlock Text="This mod buffs all AI troops with customizable difficulty."
                       Foreground="White"
                       Margin="0,5"/>

            <TextBlock Text="AI DIFFICULTY"
                       Foreground="#77AAFF" 
                       FontWeight="Bold" 
                       Margin="0,5"/>

            <StackPanel IsEnabled="{Binding IsPresetSelectionEnabled}">
                <ItemsControl ItemsSource="{Binding DifficultyNameLabels}"
                              Margin="0,0,0,4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       Foreground="White"
                                       TextAlignment="{Binding Alignment}"
                                       FontSize="12"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Slider Width="Auto"
                        Minimum="0"
                        Maximum="5"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        IsMoveToPointEnabled="True"
                        TickPlacement="BottomRight"
                        Value="{Binding SelectedDifficultySliderValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

                <ItemsControl ItemsSource="{Binding DifficultyMultiplierLabels}"
                              Margin="0,5,0,10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       Foreground="White"
                                       TextAlignment="{Binding Alignment}"
                                       FontSize="12"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Separator Background="#444466" Margin="0,10"/>

            <CheckBox Content="Customize Multipliers"
                      IsChecked="{Binding CustomizeMultipliers, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                      Foreground="White"
                      Margin="0,8,0,5"/>

            <Grid IsEnabled="{Binding CustomizeMultipliers}">
                <Grid.Style>
                    <Style TargetType="{x:Type Grid}">
                        <Setter Property="Opacity" Value="1.0"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.Resources>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Foreground" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#777788"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                </Grid.Resources>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="AI Unit HP Multiplier"
                           VerticalAlignment="Center"
                           Margin="0,5"/>

                <TextBox Grid.Row="0" Grid.Column="2"
                         Width="80"
                         Margin="0,5"
                         Text="{Binding HpMultiplierText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         ui:KeyboardCaptureBinding.Enabled="True"/>

                <TextBlock Grid.Row="1" Grid.Column="2"
                           Text="0.01 - 100.0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="0"
                           FontSize="10"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="AI Unit Damage Multiplier"
                           VerticalAlignment="Center"
                           Margin="0,5"/>

                <TextBox Grid.Row="2" Grid.Column="2"
                         Width="80"
                         Margin="0,5"
                         Text="{Binding DmgMultiplierText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         ui:KeyboardCaptureBinding.Enabled="True"/>

                <TextBlock Grid.Row="3" Grid.Column="2"
                           Text="0.01 - 100.0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="0"
                           FontSize="10"/>
            </Grid>

            <Separator Background="#444466" Margin="0,10"/>

            <TextBlock Text="The multipliers stack with any other HP and Damage modifiers. In multiplayer, only the host setting is effective."
                       Foreground="White"
                       TextWrapping="Wrap"
                       Margin="0,5"/>
        </StackPanel>
    </ScrollViewer>
</Grid>
