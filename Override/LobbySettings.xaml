<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
    <Grid.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Grid.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <Grid IsEnabled="{Binding IsHost}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="AI Unit HP"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,5"/>

                <TextBox Grid.Row="0" Grid.Column="2"
                         Width="80"
                         Margin="0,5"
                         Text="{Binding HpMultiplier, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                         Foreground="White"
                         Background="#333355"
                         BorderBrush="#555577"
                         Padding="4,2"
                         ui:KeyboardCaptureBinding.Enabled="True"/>

                <TextBlock Grid.Row="0" Grid.Column="3"
                           Text=" x"
                           Foreground="White"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="0"/>

                <TextBlock Grid.Row="1" Grid.Column="2"
                           Text="0.01 - 100.0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="0"
                           FontSize="10"/>
            </Grid>

            <TextBlock Text=""
                       Foreground="White"
                       Margin="0,5"
                       FontSize="12"/>

            <TextBlock Text="The HP multiplier affects all AI troops. 1.0 corresponds to the default Unit HP."
                       Foreground="White"
                       Margin="0,5"
                       FontSize="12"/>

            <TextBlock Text="It also stacks with the difficulty multiplier, and any other HP modifiers."
                       Foreground="White"
                       Margin="0,5"
                       FontSize="12"/>

            <TextBlock Text="Example: Setting the multiplier to 3.0 triples the HP of all AI units."
                       Foreground="White"
                       Margin="0,5"
                       FontSize="12"/>

            <TextBlock Text="In multiplayer, only the host setting is effective."
                       Foreground="White"
                       Margin="0,5"
                       FontSize="12"/>

            <TextBlock Text="Beware: Setting the multiplier too high may make Defeat inevitable :)"
                       Foreground="White"
                       Margin="0,5"
                       FontSize="12"/>
        </StackPanel>
    </ScrollViewer>
</Grid>
